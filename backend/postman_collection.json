{
  "info": {
    "_postman_id": "smartstock-collection",
    "name": "SmartStock Enterprise API",
    "description": "Complete API collection for SmartStock Enterprise with 7-minute atomic locking",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9442290033\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/otp/send",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "otp", "send"]
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9442290033\",\n  \"otp\": \"123456\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/otp/verify",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "otp", "verify"]
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8080/api/products",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "products"]
            }
          }
        },
        {
          "name": "Get Products by Category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8080/api/products?category=groceries",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "products"],
              "query": [
                {
                  "key": "category",
                  "value": "groceries"
                }
              ]
            }
          }
        },
        {
          "name": "Get Single Product",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8080/api/products/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "products", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Shopping Cart - Smart Locking",
      "item": [
        {
          "name": "Add to Cart (Stock >= 10)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9442290033\",\n  \"productId\": 1,\n  \"quantity\": 2\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/cart/add",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "cart", "add"]
            },
            "description": "When stock >= 10: Normal add (no lock), frontend handles"
          }
        },
        {
          "name": "Add to Cart (Stock < 10) - ATOMIC LOCK",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9442290033\",\n  \"productId\": 11,\n  \"quantity\": 1\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/cart/add",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "cart", "add"]
            },
            "description": "When stock < 10: Creates 7-min atomic lock, returns lockId"
          }
        },
        {
          "name": "Get Active Locks for User",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8080/api/cart?phone=9442290033",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "cart"],
              "query": [
                {
                  "key": "phone",
                  "value": "9442290033"
                }
              ]
            }
          }
        },
        {
          "name": "Remove Locked Item",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "http://localhost:8080/api/cart/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "cart", "1"]
            }
          }
        },
        {
          "name": "Extend Lock +7 Minutes",
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:8080/api/cart/extend/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "cart", "extend", "1"]
            }
          }
        }
      ]
    },
