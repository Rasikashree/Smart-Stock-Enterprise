{
  "version": 2,
  "name": "SmartStock Enterprise Backend",
  "builds": [
    {
      "src": "backend/pom.xml",
      "use": "@vercel/java",
      "config": {
        "memory": 1024,
        "runtime": "java17"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/SmartStockAppApplication.java"
    },
    {
      "src": "/health",
      "dest": "backend/SmartStockAppApplication.java"
    }
  ],
  "env": {
    "SPRING_DATASOURCE_URL": "@db_url",
    "SPRING_DATASOURCE_USERNAME": "@db_user",
    "SPRING_DATASOURCE_PASSWORD": "@db_password",
    "RAZORPAY_KEY": "@razorpay_key",
    "RAZORPAY_SECRET": "@razorpay_secret"
  }
}
